<section
  class="hero full-width{% unless section.settings.shopify_video or section.settings.video_url != blank or section.settings.image %} hero--no-media{% endunless %}"
>
  {% if section.settings.video_url != blank %}
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      poster="{% if section.settings.image %}{{ section.settings.image | image_url: width: 1920 }}{% endif %}"
    >
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {% elsif section.settings.shopify_video %}
    {{ section.settings.shopify_video | video_tag:
      autoplay: true,
      muted: true,
      loop: true,
      playsinline: true,
      class: 'hero__video'
    }}
  {% elsif section.settings.image %}
    <img
      class="hero__image"
      src="{{ section.settings.image | image_url: width: 1920 }}"
      alt="{{ section.settings.image.alt | escape }}"
      loading="eager"
      width="1920"
      height="900"
    >
  {% endif %}

  <div class="hero__overlay"></div>

  <div class="hero__content">
    {% if section.settings.subtitle != blank %}
      <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}

    <h1 class="hero__title">{{ section.settings.title }}</h1>

    {% if section.settings.description != blank %}
      <p class="hero__description">{{ section.settings.description }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_url }}" class="hero__button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}

    {% if section.settings.show_rating %}
      <div class="hero__rating">
        <span class="hero__stars">★★★★★</span>
        <span class="hero__rating-text">{{ section.settings.rating_text }}</span>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 85vh;
    overflow: hidden;
    background-color: #1a1a2e;
  }

  .hero.hero--no-media {
    background:
      radial-gradient(ellipse 80% 60% at 50% 20%, rgba(99, 102, 241, 0.22), transparent 55%),
      radial-gradient(ellipse 70% 50% at 80% 80%, rgba(15, 118, 110, 0.18), transparent 50%),
      linear-gradient(165deg, #0f172a 0%, #1e1b4b 45%, #0f172a 100%);
  }

  .hero__video,
  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.6));
    z-index: 2;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #fff;
    max-width: 52rem;
    padding: clamp(2.75rem, 6vw, 4.5rem) var(--page-margin, 1.5rem);
  }

  .hero__subtitle {
    font-size: clamp(0.85rem, 1.8vw, 1rem);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    margin-bottom: 1.25rem;
    opacity: 0.85;
  }

  .hero__title {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 700;
    line-height: 1.12;
    margin-bottom: 1.35rem;
  }

  .hero__description {
    font-size: clamp(1.08rem, 2.2vw, 1.28rem);
    line-height: 1.68;
    opacity: 0.9;
    margin-bottom: 2.25rem;
    max-width: 38rem;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__button {
    display: inline-block;
    background-color: #fff;
    color: #000;
    padding: 1.1rem 2.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    border-radius: 4px;
    transition: background-color 0.3s, transform 0.2s;
  }

  .hero__button:hover {
    background-color: #f0f0f0;
    transform: translateY(-2px);
  }

  .hero__rating {
    margin-top: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
  }

  .hero__stars {
    color: #f5c518;
    font-size: 1.35rem;
    letter-spacing: 0.12em;
  }

  .hero__rating-text {
    font-size: 1.05rem;
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
    }

    .hero__button {
      padding: 14px 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "video",
      "id": "shopify_video",
      "label": "Video (upload)",
      "info": "Upload a video directly to Shopify. This takes priority over an external URL."
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (external)",
      "info": "Direct link to an .mp4 file. Used if no Shopify video is uploaded."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback Image",
      "info": "Shown while video loads, or if no video is set."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Trusted by 25,000+ Customers"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Radiant Skin Powered by Light"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Professional-grade LED mask for smoother, firmer, younger-looking skin."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "GET STARTED TODAY"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "4.9 Excellent"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
