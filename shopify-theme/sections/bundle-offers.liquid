{% assign bundle_1 = section.settings.bundle_product_1 %}
{% assign bundle_2 = section.settings.bundle_product_2 %}
{% assign bundle_3 = section.settings.bundle_product_3 %}

{% if bundle_1 != blank or bundle_2 != blank or bundle_3 != blank %}
<section class="bundle-section">
  <div class="bundle-section__inner">
    <h3 class="bundle-section__heading">{{ section.settings.heading }}</h3>

    {% for i in (1..3) %}
      {% case i %}
        {% when 1 %}
          {% assign bp = bundle_1 %}
          {% assign savings = section.settings.bundle_savings_1 %}
        {% when 2 %}
          {% assign bp = bundle_2 %}
          {% assign savings = section.settings.bundle_savings_2 %}
        {% when 3 %}
          {% assign bp = bundle_3 %}
          {% assign savings = section.settings.bundle_savings_3 %}
      {% endcase %}

      {% if bp != blank %}
        <div class="bundle-card">
          <div class="bundle-card__left">
            <div class="bundle-card__image">
              {% if bp.featured_image %}
                <img
                  src="{{ bp.featured_image | image_url: width: 140 }}"
                  alt="{{ bp.title | escape }}"
                  width="140"
                  height="140"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <div class="bundle-card__info">
              <p class="bundle-card__name">{{ bp.title }}</p>
              {% if bp.variants.size > 1 %}
                <select class="bundle-card__select" data-bundle="{{ i }}">
                  {% for variant in bp.variants %}
                    <option value="{{ variant.id }}">{{ variant.title }}</option>
                  {% endfor %}
                </select>
              {% endif %}
            </div>
          </div>
          <div class="bundle-card__right">
            <div class="bundle-card__pricing">
              <span class="bundle-card__price">{{ bp.price | money }}</span>
              {% if savings != blank %}
                <span class="bundle-card__save">{{ savings }}</span>
              {% elsif bp.compare_at_price > bp.price %}
                <span class="bundle-card__save">SAVE {{ bp.compare_at_price | minus: bp.price | money }}</span>
              {% endif %}
            </div>
            <form method="post" action="/cart/add">
              <input type="hidden" name="id" value="{{ bp.selected_or_first_available_variant.id }}" class="bundle-vid-{{ i }}">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="bundle-card__btn"{% unless bp.available %} disabled{% endunless %}>
                {% if bp.available %}Add to Cart{% else %}Sold Out{% endif %}
              </button>
            </form>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

<script>
  document.querySelectorAll('.bundle-card__select').forEach(function(s) {
    s.addEventListener('change', function() {
      var input = document.querySelector('.bundle-vid-' + this.dataset.bundle);
      if (input) input.value = this.value;
    });
  });
</script>

{% stylesheet %}
  .bundle-section {
    padding: 0 24px 60px;
  }

  .bundle-section__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding-left: calc(50% + 24px);
  }

  @media (max-width: 900px) {
    .bundle-section__inner {
      padding-left: 0;
      max-width: 550px;
    }
  }

  .bundle-section__heading {
    font-size: 1.1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 14px;
  }

  .bundle-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px;
    border: 2px solid #d4e8d0;
    border-radius: 14px;
    margin-bottom: 10px;
    background: #fafffe;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .bundle-card:hover {
    border-color: #a8d5a0;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .bundle-card__left {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 0;
  }

  .bundle-card__image {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: #f0f0f0;
  }

  .bundle-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bundle-card__info {
    min-width: 0;
  }

  .bundle-card__name {
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bundle-card__select {
    font-size: 13px;
    color: #555;
    padding: 4px 8px;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
  }

  .bundle-card__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
    margin-left: 12px;
  }

  .bundle-card__pricing {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bundle-card__price {
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
  }

  .bundle-card__save {
    font-size: 11px;
    font-weight: 700;
    color: #16a34a;
    background: #dcfce7;
    padding: 3px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  .bundle-card__btn {
    background: #d4edda;
    color: #1a1a1a;
    border: 1px solid #b8d9be;
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
    font-family: inherit;
    white-space: nowrap;
  }

  .bundle-card__btn:hover {
    background: #c1e6c9;
  }

  .bundle-card__btn[disabled] {
    background: #eee;
    color: #999;
    border-color: #ddd;
    cursor: not-allowed;
  }

  @media (max-width: 500px) {
    .bundle-card {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }

    .bundle-card__right {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      margin-left: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bundle Offers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buy More and Save"
    },
    {
      "type": "product",
      "id": "bundle_product_1",
      "label": "Bundle Product 1"
    },
    {
      "type": "text",
      "id": "bundle_savings_1",
      "label": "Savings Text 1",
      "info": "e.g. 'SAVE $10'. Auto-calculated if left blank."
    },
    {
      "type": "product",
      "id": "bundle_product_2",
      "label": "Bundle Product 2"
    },
    {
      "type": "text",
      "id": "bundle_savings_2",
      "label": "Savings Text 2"
    },
    {
      "type": "product",
      "id": "bundle_product_3",
      "label": "Bundle Product 3"
    },
    {
      "type": "text",
      "id": "bundle_savings_3",
      "label": "Savings Text 3"
    }
  ],
  "presets": [
    {
      "name": "Bundle Offers"
    }
  ]
}
{% endschema %}
