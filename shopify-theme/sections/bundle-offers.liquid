{% assign bundle_1 = section.settings.bundle_product_1 %}
{% assign bundle_2 = section.settings.bundle_product_2 %}
{% assign bundle_3 = section.settings.bundle_product_3 %}

{% if bundle_1 != blank or bundle_2 != blank or bundle_3 != blank %}
<section class="bundle-section full-width" id="bundle-offers-{{ section.id }}">
  <div class="bundle-section__inner">
    {% if section.settings.section_heading != blank %}
      <h2 class="bundle-section__title">{{ section.settings.section_heading }}</h2>
    {% endif %}

    {% for i in (1..3) %}
      {% case i %}
        {% when 1 %}
          {% assign bp = bundle_1 %}
          {% assign savings = section.settings.bundle_savings_1 %}
          {% assign qty_override = section.settings.bundle_qty_override_1 %}
        {% when 2 %}
          {% assign bp = bundle_2 %}
          {% assign savings = section.settings.bundle_savings_2 %}
          {% assign qty_override = section.settings.bundle_qty_override_2 %}
        {% when 3 %}
          {% assign bp = bundle_3 %}
          {% assign savings = section.settings.bundle_savings_3 %}
          {% assign qty_override = section.settings.bundle_qty_override_3 %}
      {% endcase %}

      {% if bp != blank %}
        {% assign v0 = bp.selected_or_first_available_variant %}
        <div class="bundle-offer">
          <p class="bundle-offer__eyebrow">{{ section.settings.bundle_label }}</p>

          {% if bp.variants.size > 1 %}
            <label class="visually-hidden" for="bundle-variant-{{ section.id }}-{{ i }}">{{ bp.title }} — option</label>
            <select
              id="bundle-variant-{{ section.id }}-{{ i }}"
              class="bundle-offer__variant-select"
              data-bundle="{{ i }}"
            >
              {% for variant in bp.variants %}
                <option
                  value="{{ variant.id }}"
                  {% if variant.id == v0.id %}selected{% endif %}
                  {% unless variant.available %}disabled{% endunless %}
                >
                  {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %}
                </option>
              {% endfor %}
            </select>
          {% endif %}

          <div class="bundle-offer__frame">
            <form method="post" action="{{ routes.cart_add_url }}" class="bundle-offer__form">
              <input type="hidden" name="id" value="{{ v0.id }}" class="bundle-vid-{{ i }}">
              <input type="hidden" name="quantity" value="1">
              <button
                type="submit"
                class="bundle-offer__submit"
                {% unless bp.available %}disabled{% endunless %}
              >
                <span class="bundle-offer__inner">
                  <span class="bundle-offer__name">{{ bp.title }}</span>
                  <span class="bundle-offer__qty" aria-hidden="true">
                    <span class="bundle-offer__qty-label">Quantity:</span>
                    <span
                      class="bundle-offer__qty-value"
                      data-bundle-qty-display="{{ i }}"
                      {% if qty_override != blank %}data-qty-locked="1"{% endif %}
                    >
                      {% if qty_override != blank %}
                        {{ qty_override }}
                      {% elsif v0.title != blank and v0.title != 'Default Title' %}
                        {{ v0.title }}
                      {% else %}
                        1
                      {% endif %}
                    </span>
                  </span>
                </span>
              </button>
            </form>
          </div>

          {% if savings != blank %}
            <p class="bundle-offer__save-tag">{{ savings }}</p>
          {% elsif bp.compare_at_price > bp.price %}
            <p class="bundle-offer__save-tag">
              Save
              {{ bp.compare_at_price | minus: bp.price | money }}
            </p>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('bundle-offers-{{ section.id }}');
    if (!root) return;

    root.querySelectorAll('.bundle-offer__variant-select').forEach(function (sel) {
      var n = sel.dataset.bundle;
      var input = root.querySelector('.bundle-vid-' + n);
      var qtyEl = root.querySelector('[data-bundle-qty-display="' + n + '"]');
      sel.addEventListener('change', function () {
        if (input) input.value = sel.value;
        var opt = sel.options[sel.selectedIndex];
        if (qtyEl && opt && !qtyEl.hasAttribute('data-qty-locked')) {
          var t = (opt.textContent || '').split('—')[0].trim();
          if (t) qtyEl.textContent = t;
        }
      });
    });
  })();
</script>

{% stylesheet %}
  .bundle-section {
    padding: 0 var(--page-margin, 1.25rem) var(--section-space-y-compact, clamp(2.75rem, 6vw, 5rem));
    font-family: var(--font-brand, var(--font-primary--family), system-ui, sans-serif);
  }

  .bundle-section__inner {
    max-width: min(640px, 100%);
    margin: 0 auto;
  }

  .bundle-section__title {
    margin: 0 0 1.25rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: #262626;
    letter-spacing: -0.02em;
  }

  .bundle-offer {
    margin-bottom: 1.35rem;
  }

  .bundle-offer:last-child {
    margin-bottom: 0;
  }

  .bundle-offer__eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #525252;
    letter-spacing: 0.01em;
  }

  .bundle-offer__variant-select {
    width: 100%;
    max-width: 100%;
    margin-bottom: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    border: 1px solid #d4d4d4;
    border-radius: 8px;
    background: #fff;
    color: #171717;
    font-family: inherit;
  }

  .bundle-offer__frame {
    background: #d4d4d4;
    border: 1px solid #000000;
    border-radius: 18px;
    padding: 7px;
    box-sizing: border-box;
  }

  .bundle-offer__form {
    margin: 0;
  }

  .bundle-offer__submit {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    font: inherit;
    text-align: left;
  }

  .bundle-offer__submit:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .bundle-offer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.15rem;
    min-height: 4.25rem;
    padding: 1.05rem 1.35rem;
    background: #171717;
    border: 1px solid #000000;
    border-radius: 12px;
    box-sizing: border-box;
    width: 100%;
    transition: filter 0.15s ease, transform 0.15s ease;
  }

  .bundle-offer__submit:not(:disabled):hover .bundle-offer__inner {
    filter: brightness(1.08);
  }

  .bundle-offer__submit:not(:disabled):active .bundle-offer__inner {
    transform: scale(0.998);
  }

  .bundle-offer__name {
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    text-align: left;
    flex: 1;
    min-width: 0;
  }

  .bundle-offer__qty {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    text-align: right;
    flex-shrink: 0;
    gap: 0.1rem;
  }

  .bundle-offer__qty-label {
    font-size: 0.6875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.2;
  }

  .bundle-offer__qty-value {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.2;
  }

  .bundle-offer__save-tag {
    margin: 0.5rem 0 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: #16a34a;
    letter-spacing: 0.02em;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bundle Offers",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section title (optional)",
      "info": "Leave blank to show only the per-bundle label."
    },
    {
      "type": "text",
      "id": "bundle_label",
      "label": "Label above each bundle",
      "default": "Bundle and Save"
    },
    {
      "type": "header",
      "content": "Bundle 1"
    },
    {
      "type": "product",
      "id": "bundle_product_1",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "bundle_qty_override_1",
      "label": "Quantity text (right side)",
      "info": "e.g. 50. Shown next to “Quantity:”. If empty, uses the selected variant name."
    },
    {
      "type": "text",
      "id": "bundle_savings_1",
      "label": "Savings line (optional)",
      "info": "e.g. SAVE $10. Shown under the button."
    },
    {
      "type": "header",
      "content": "Bundle 2"
    },
    {
      "type": "product",
      "id": "bundle_product_2",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "bundle_qty_override_2",
      "label": "Quantity text (right side)"
    },
    {
      "type": "text",
      "id": "bundle_savings_2",
      "label": "Savings line (optional)"
    },
    {
      "type": "header",
      "content": "Bundle 3"
    },
    {
      "type": "product",
      "id": "bundle_product_3",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "bundle_qty_override_3",
      "label": "Quantity text (right side)"
    },
    {
      "type": "text",
      "id": "bundle_savings_3",
      "label": "Savings line (optional)"
    }
  ],
  "presets": [
    {
      "name": "Bundle Offers"
    }
  ]
}
{% endschema %}
