<div class="announcement-bar full-width">
  <div class="announcement-bar__viewport">
    <div class="announcement-bar__track">
      {% if section.blocks.size > 0 %}
        <div class="announcement-bar__segment">
          {% for block in section.blocks %}
            <span class="announcement-bar__item" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </span>
          {% endfor %}
        </div>
        <div class="announcement-bar__segment" aria-hidden="true">
          {% for block in section.blocks %}
            <span class="announcement-bar__item">
              {{ block.settings.text }}
            </span>
          {% endfor %}
        </div>
      {% else %}
        <div class="announcement-bar__segment announcement-bar__segment--fallback">
          <span class="announcement-bar__item">Free shipping across the USA &amp; Canada</span>
          <span class="announcement-bar__item">Wake up better — sleep tech that works</span>
          <span class="announcement-bar__item">Bundle &amp; save — build your sleep kit</span>
        </div>
        <div class="announcement-bar__segment announcement-bar__segment--fallback" aria-hidden="true">
          <span class="announcement-bar__item">Free shipping across the USA &amp; Canada</span>
          <span class="announcement-bar__item">Wake up better — sleep tech that works</span>
          <span class="announcement-bar__item">Bundle &amp; save — build your sleep kit</span>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .announcement-bar {
    background-color: #000;
    color: #fff;
    overflow: hidden;
    padding: 0.85rem 0;
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    min-height: 3rem;
    display: flex;
    align-items: center;
  }

  .announcement-bar__viewport {
    overflow: hidden;
    width: 100%;
  }

  .announcement-bar__track {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    width: max-content;
    will-change: transform;
    animation: announcement-marquee 35s linear infinite;
  }

  .announcement-bar__segment {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    flex-shrink: 0;
    gap: clamp(2.5rem, 6vw, 4.5rem);
    padding-right: clamp(2.5rem, 6vw, 4.5rem);
  }

  .announcement-bar__item {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .announcement-bar__item::after {
    content: '\2022';
    font-size: 8px;
    opacity: 0.5;
    margin-left: 3rem;
  }

  @keyframes announcement-marquee {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }

  .announcement-bar:hover .announcement-bar__track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement-bar__track {
      animation: none;
      justify-content: center;
      flex-wrap: wrap;
      width: 100%;
      max-width: 100%;
    }

    .announcement-bar__segment[aria-hidden='true'] {
      display: none;
    }

    .announcement-bar__viewport {
      overflow: visible;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Announcement text here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Free Shipping on Orders Over $100" } },
        { "type": "announcement", "settings": { "text": "Clinically Proven Results" } },
        { "type": "announcement", "settings": { "text": "Science-Backed Beauty" } }
      ]
    }
  ]
}
{% endschema %}
