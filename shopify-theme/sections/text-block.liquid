<section class="text-block">
  <h2 class="text-block__title">{{ section.settings.title }}</h2>
  {% if section.settings.description != blank %}
    <p class="text-block__description">{{ section.settings.description }}</p>
  {% endif %}
</section>

{% stylesheet %}
  .text-block {
    text-align: center;
    max-width: 46rem;
    margin: 0 auto;
    padding: var(--section-space-y, clamp(3.5rem, 9vw, 7rem)) var(--page-margin, 1.5rem);
  }

  .text-block__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.18;
    margin-bottom: 1.35rem;
    color: #1a1a1a;
    letter-spacing: -0.02em;
  }

  .text-block__description {
    font-size: clamp(1.08rem, 2vw, 1.25rem);
    line-height: 1.75;
    color: #444;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Text Block",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Your Heading Here"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Add a description here."
    }
  ],
  "presets": [
    {
      "name": "Text Block"
    }
  ]
}
{% endschema %}
