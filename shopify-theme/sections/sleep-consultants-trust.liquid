{% comment %}
  Trust strip (static icon row) + headline + 4 pillars + optional CTA.
{% endcomment %}

<section class="sleep-trust full-width">
  <div class="sleep-trust__inner">
    <div class="sleep-trust__strip" role="presentation">
      {% for i in (1..3) %}
        {% liquid
          case i
            when 1
              assign st = section.settings.strip_1_text
              assign si = section.settings.strip_1_icon
            when 2
              assign st = section.settings.strip_2_text
              assign si = section.settings.strip_2_icon
            when 3
              assign st = section.settings.strip_3_text
              assign si = section.settings.strip_3_icon
          endcase
        %}
        <span class="sleep-trust__strip-item">
          <span class="sleep-trust__strip-icon" aria-hidden="true">
            {% case si %}
              {% when 'trophy' %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
              {% when 'shield' %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {% when 'bag' %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              {% when 'star' %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {% else %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {% endcase %}
          </span>
          <span class="sleep-trust__strip-text">{{ st }}</span>
        </span>
        {% unless forloop.last %}
          <span class="sleep-trust__strip-dot" aria-hidden="true"></span>
        {% endunless %}
      {% endfor %}
    </div>

    {% if section.settings.heading != blank %}
      <h2 class="sleep-trust__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="sleep-trust__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="sleep-trust__grid" role="list">
        {% for block in section.blocks %}
          <article class="sleep-trust__card" role="listitem" {{ block.shopify_attributes }}>
            <div class="sleep-trust__card-icon" aria-hidden="true">
              {% case block.settings.icon %}
                {% when 'medal' %}
                  <svg class="sleep-trust__card-svg" width="56" height="56" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle class="sleep-trust__icon-line" cx="32" cy="22" r="13" stroke-width="1.75"/>
                    <polygon class="sleep-trust__icon-accent-fill" points="32,14 34.2,20.2 40.8,20.2 35.3,24.1 37.5,30.8 32,27 26.5,30.8 28.7,24.1 23.2,20.2 29.8,20.2"/>
                    <path class="sleep-trust__icon-accent" d="M21 35 L19 50 L27 45 L32 49 L37 45 L45 50 L43 35 Z" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% when 'certificate' %}
                  <svg class="sleep-trust__card-svg" width="56" height="56" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect class="sleep-trust__icon-line sleep-trust__icon-faint" x="9" y="18" width="26" height="34" rx="2" stroke-width="1.5"/>
                    <rect class="sleep-trust__icon-line" x="21" y="12" width="30" height="38" rx="2.5" stroke-width="1.75" fill="#fff"/>
                    <circle class="sleep-trust__icon-accent-fill" cx="44" cy="22" r="5"/>
                    <line class="sleep-trust__icon-line" x1="28" y1="32" x2="47" y2="32" stroke-width="1.5"/>
                    <line class="sleep-trust__icon-line" x1="28" y1="39" x2="44" y2="39" stroke-width="1.5"/>
                  </svg>
                {% when 'globe' %}
                  <svg class="sleep-trust__card-svg" width="56" height="56" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle class="sleep-trust__icon-line" cx="32" cy="32" r="17" stroke-width="1.75"/>
                    <ellipse class="sleep-trust__icon-line" cx="32" cy="32" rx="9" ry="17" stroke-width="1.5"/>
                    <line class="sleep-trust__icon-line" x1="15" y1="32" x2="49" y2="32" stroke-width="1.5"/>
                    <path class="sleep-trust__icon-line" d="M32 15c-6 8-6 24 0 32" stroke-width="1.5"/>
                    <path class="sleep-trust__icon-accent-fill" d="M43 17 54 13 50 26 46 24Z"/>
                  </svg>
                {% when 'chat' %}
                  <svg class="sleep-trust__card-svg" width="56" height="56" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path class="sleep-trust__icon-line" d="M12 20c0-5 4-9 10-9h22c6 0 10 4 10 10v16c0 5-4 9-9 9H28l-12 9v-9h-2c-5 0-8-4-8-9V20Z" stroke-width="1.75" stroke-linejoin="round"/>
                    <g class="sleep-trust__icon-accent-fill" transform="translate(14,24) scale(0.38)">
                      <polygon points="12,2 15,10 24,10 17,15 19.5,24 12,19.5 4.5,24 7,15 0,10 9,10"/>
                    </g>
                    <g class="sleep-trust__icon-accent-fill" transform="translate(27,24) scale(0.38)">
                      <polygon points="12,2 15,10 24,10 17,15 19.5,24 12,19.5 4.5,24 7,15 0,10 9,10"/>
                    </g>
                    <g class="sleep-trust__icon-accent-fill" transform="translate(40,24) scale(0.38)">
                      <polygon points="12,2 15,10 24,10 17,15 19.5,24 12,19.5 4.5,24 7,15 0,10 9,10"/>
                    </g>
                  </svg>
                {% else %}
                  <svg class="sleep-trust__card-svg" width="56" height="56" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <polygon class="sleep-trust__icon-accent-fill" points="32,12 36.5,24.5 50,25.5 40,34 43.5,48 32,41 20.5,48 24,34 14,25.5 27.5,24.5"/>
                  </svg>
              {% endcase %}
            </div>
            {% if block.settings.title != blank %}
              <h3 class="sleep-trust__card-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="sleep-trust__card-text">{{ block.settings.text }}</p>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.cta_heading != blank or section.settings.cta_text != blank or section.settings.cta_label != blank %}
      <div class="sleep-trust__cta">
        {% if section.settings.cta_heading != blank %}
          <h3 class="sleep-trust__cta-heading">{{ section.settings.cta_heading }}</h3>
        {% endif %}
        {% if section.settings.cta_text != blank %}
          <p class="sleep-trust__cta-text">{{ section.settings.cta_text }}</p>
        {% endif %}
        {% if section.settings.cta_label != blank %}
          <a class="sleep-trust__cta-button" href="{% if section.settings.cta_link != blank %}{{ section.settings.cta_link }}{% else %}{{ routes.root_url }}{% endif %}">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .sleep-trust {
    font-family: var(--font-brand, var(--font-primary--family), system-ui, sans-serif);
    background: #f3f4f6;
    color: #111111;
    border-top: 1px solid #e5e7eb;
  }

  .sleep-trust__inner {
    max-width: min(1120px, 100%);
    margin: 0 auto;
    padding: var(--section-space-y, clamp(3.5rem, 8vw, 7rem)) var(--page-margin, 1.25rem) var(--section-space-y, clamp(3.5rem, 8vw, 7rem));
  }

  .sleep-trust__card-svg .sleep-trust__icon-line {
    stroke: #111111;
    fill: none;
  }

  .sleep-trust__card-svg .sleep-trust__icon-faint {
    opacity: 0.36;
  }

  .sleep-trust__card-svg .sleep-trust__icon-accent {
    stroke: var(--color-accent);
    fill: none;
  }

  .sleep-trust__card-svg .sleep-trust__icon-accent-fill,
  .sleep-trust__icon-accent-fill polygon {
    fill: var(--color-accent);
  }

  .sleep-trust__strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem 0.5rem;
    margin-bottom: clamp(1.75rem, 4vw, 2.25rem);
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .sleep-trust__strip-item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #525252;
  }

  .sleep-trust__strip-icon {
    display: flex;
    color: #404040;
  }

  .sleep-trust__strip-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #d1d5db;
    margin: 0 0.65rem;
  }

  .sleep-trust__heading {
    margin: 0 0 0.85rem;
    font-size: clamp(1.75rem, 3.8vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
    line-height: 1.2;
    color: #111111;
  }

  .sleep-trust__subheading {
    margin: 0 auto 2.5rem;
    max-width: 40rem;
    text-align: center;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    font-weight: 400;
    line-height: 1.7;
    color: #525252;
  }

  .sleep-trust__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: clamp(2.5rem, 6vw, 3.5rem);
  }

  @media (max-width: 900px) {
    .sleep-trust__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .sleep-trust__grid {
      grid-template-columns: 1fr;
    }

    .sleep-trust__strip {
      flex-direction: column;
      gap: 0.75rem;
    }

    .sleep-trust__strip-dot {
      display: none;
    }
  }

  .sleep-trust__card {
    position: relative;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 22px;
    padding: clamp(2.1rem, 4vw, 2.85rem) 1.5rem 2.25rem;
    text-align: center;
    box-shadow:
      0 2px 4px rgba(15, 23, 42, 0.04),
      0 12px 28px rgba(15, 23, 42, 0.1),
      0 24px 48px rgba(15, 23, 42, 0.08);
    transition: transform 0.28s ease, box-shadow 0.28s ease;
  }

  .sleep-trust__card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 6px 12px rgba(15, 23, 42, 0.06),
      0 20px 40px rgba(15, 23, 42, 0.12),
      0 36px 64px rgba(15, 23, 42, 0.1);
  }

  .sleep-trust__card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.35rem;
    min-height: 3.75rem;
  }

  .sleep-trust__card-svg {
    flex-shrink: 0;
  }

  .sleep-trust__card-title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.08rem, 2vw, 1.22rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.25;
    color: #111111;
  }

  .sleep-trust__card-text {
    margin: 0;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.68;
    color: #525252;
  }

  .sleep-trust__cta {
    text-align: center;
    margin-top: 0.25rem;
    padding-top: clamp(1.75rem, 4vw, 2.25rem);
    border-top: 1px solid #e5e7eb;
  }

  .sleep-trust__cta-heading {
    margin: 0 0 0.5rem;
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #111111;
  }

  .sleep-trust__cta-text {
    margin: 0 auto 1.25rem;
    max-width: 28rem;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    color: #525252;
  }

  .sleep-trust__cta-button {
    display: inline-block;
    padding: 0.95rem 1.85rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-on-accent);
    background: var(--color-accent);
    border-radius: 6px;
    transition: opacity 0.2s ease, transform 0.2s ease, filter 0.2s ease;
  }

  .sleep-trust__cta-button:hover {
    opacity: 0.95;
    transform: translateY(-1px);
    filter: brightness(1.05);
  }
{% endstylesheet %}

