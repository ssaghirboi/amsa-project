{% assign product = section.settings.product %}

{{ 'product-highlight.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-variant-picker.js' | asset_url }}" defer></script>

<section
  class="product-highlight"
  id="ProductHighlight-{{ section.id }}"
>
  <div class="product-highlight__panel">
    <div class="product-highlight__inner">
      <div class="product-highlight__gallery">
        <div class="product-highlight__main-image" data-ph-main-viewport>
          {% if product and product.images.size > 0 %}
            {% assign ph_slide_total = product.images.size %}
            <div
              class="product-highlight__carousel-track"
              data-ph-carousel-track
              style="--ph-slide: 0; --ph-slides: {{ ph_slide_total }};"
            >
              {% for img in product.images limit: 24 %}
                <div class="product-highlight__carousel-cell">
                  <img
                    data-ph-main
                    data-ph-slide-index="{{ forloop.index0 }}"
                    src="{{ img | image_url: width: 1200 }}"
                    alt="{{ img.alt | default: product.title | escape }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="1200"
                    height="1200"
                  >
                </div>
              {% endfor %}
            </div>
          {% elsif product and product.featured_image %}
            <div
              class="product-highlight__carousel-track"
              data-ph-carousel-track
              style="--ph-slide: 0; --ph-slides: 1;"
            >
              <div class="product-highlight__carousel-cell">
                <img
                  data-ph-main
                  data-ph-slide-index="0"
                  src="{{ product.featured_image | image_url: width: 1200 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="1200"
                  height="1200"
                >
              </div>
            </div>
          {% elsif section.settings.image %}
            <div
              class="product-highlight__carousel-track"
              data-ph-carousel-track
              style="--ph-slide: 0; --ph-slides: 1;"
            >
              <div class="product-highlight__carousel-cell">
                <img
                  data-ph-main
                  data-ph-slide-index="0"
                  src="{{ section.settings.image | image_url: width: 1200 }}"
                  alt="{{ section.settings.image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="1200"
                  height="1200"
                >
              </div>
            </div>
          {% else %}
            <div class="product-highlight__placeholder" role="img" aria-label="{{ product.title | default: 'Product' }}"></div>
          {% endif %}
        </div>

        {% if product and product.images.size > 1 %}
          <div class="product-highlight__thumbnails">
            {% for img in product.images limit: 8 %}
              <button
                type="button"
                class="product-highlight__thumb{% if forloop.first %} is-active{% endif %}"
                data-ph-thumb
                data-ph-thumb-index="{{ forloop.index0 }}"
                data-full="{{ img | image_url: width: 1200 }}"
                aria-label="Show image {{ forloop.index }}"
              >
                <img
                  src="{{ img | image_url: width: 120 }}"
                  alt="{{ img.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="120"
                  height="120"
                >
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="product-highlight__details">
        {% if product %}
          {% assign fh_variant = product.selected_or_first_available_variant %}
        {% else %}
          {% assign fh_variant = nil %}
        {% endif %}

        <div class="product-highlight__title-row">
          <h2 class="product-highlight__title">
            {{ product.title | default: section.settings.fallback_title }}
          </h2>
          <div class="product-highlight__price-wrap">
            {% if product %}
              <span class="product-highlight__price" data-ph-price>{{ fh_variant.price | money }}</span>
              {% if fh_variant.compare_at_price > fh_variant.price %}
                <span class="product-highlight__compare-price" data-ph-compare-price>{{ fh_variant.compare_at_price | money }}</span>
              {% else %}
                <span class="product-highlight__compare-price" data-ph-compare-price hidden></span>
              {% endif %}
            {% else %}
              <span class="product-highlight__price">—</span>
            {% endif %}
          </div>
        </div>

        {% if section.settings.show_rating %}
          <div class="product-highlight__rating">
            <span class="product-highlight__stars" aria-hidden="true">★★★★★</span>
            <span class="product-highlight__reviews">({{ section.settings.review_count }})</span>
          </div>
        {% endif %}

        {% if product and product.description != blank %}
          <details class="product-highlight__readmore">
            <summary class="product-highlight__readmore-summary">
              <span class="product-highlight__readmore-label">{{ section.settings.read_more_label }}</span>
              <span class="product-highlight__readmore-chevron" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 9l6 6 6-6"/>
                </svg>
              </span>
            </summary>
            <div class="product-highlight__readmore-body rte">{{ product.description }}</div>
          </details>
        {% elsif section.settings.custom_description != blank %}
          <details class="product-highlight__readmore">
            <summary class="product-highlight__readmore-summary">
              <span class="product-highlight__readmore-label">{{ section.settings.read_more_label }}</span>
              <span class="product-highlight__readmore-chevron" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 9l6 6 6-6"/>
                </svg>
              </span>
            </summary>
            <div class="product-highlight__readmore-body">{{ section.settings.custom_description | escape | newline_to_br }}</div>
          </details>
        {% endif %}

        {% if product %}
          <form method="post" action="{{ routes.cart_add_url }}">
            {% if product.variants.size > 1 %}
              {% render 'product-variant-picker',
                product: product,
                section_id: section.id,
                current_variant: fh_variant
              %}
            {% else %}
              <input type="hidden" name="id" value="{{ fh_variant.id }}">
            {% endif %}
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              class="product-highlight__button product-highlight__button--primary"
              data-add-label="{{ section.settings.button_text | escape }}"
              data-sold-label="Sold out"
              {% unless fh_variant.available %}
                disabled
              {% endunless %}
            >
              {% if fh_variant.available %}
                {{ section.settings.button_text }}
              {% else %}
                Sold out
              {% endif %}
            </button>
          </form>
        {% else %}
          <span class="product-highlight__button" style="display: inline-block; opacity: 0.5; pointer-events: none;">
            {{ section.settings.button_text }}
          </span>
        {% endif %}

        {% if section.settings.subtext != blank %}
          <p class="product-highlight__subtext">{{ section.settings.subtext }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('ProductHighlight-{{ section.id }}');
    if (!root) return;
    var track = root.querySelector('[data-ph-carousel-track]');
    var fallbackMain = root.querySelector('[data-ph-main]');
    if (track || fallbackMain) {
      root.querySelectorAll('[data-ph-thumb]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var idx = parseInt(btn.getAttribute('data-ph-thumb-index'), 10);
          if (track && !Number.isNaN(idx)) {
            var imgs = track.querySelectorAll('[data-ph-main]');
            var n = imgs.length || 1;
            track.style.setProperty('--ph-slide', String(idx));
            track.style.setProperty('--ph-slides', String(n));
          } else if (fallbackMain) {
            var url = btn.getAttribute('data-full');
            if (url) {
              fallbackMain.src = url;
              fallbackMain.removeAttribute('srcset');
            }
          }
          root.querySelectorAll('[data-ph-thumb]').forEach(function (b) {
            b.classList.remove('is-active');
          });
          btn.classList.add('is-active');
        });
      });
    }
  })();
</script>

{% if template.name == 'index' %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var el = document.getElementById('ProductHighlight-{{ section.id }}');
      if (!el) return;
      var reduce =
        window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      requestAnimationFrame(function () {
        el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
      });
    });
  </script>
{% endif %}

{% schema %}
{
  "name": "Product Highlight",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Override image",
      "info": "Optional. Used when no product is selected, or as fallback."
    },
    {
      "type": "header",
      "content": "Custom text (if no product)"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback title",
      "default": "Silent Alarm Wristband"
    },
    {
      "type": "textarea",
      "id": "custom_description",
      "label": "Custom description",
      "info": "Shown when the product has no description.",
      "default": "Wake up gently with a silent vibrating alarm that won't disturb your partner. Lightweight, comfortable, and designed for the deepest sleepers."
    },
    {
      "type": "header",
      "content": "Primary action"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Add to cart label",
      "default": "Add to cart"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Line under button",
      "default": "Free shipping"
    },
    {
      "type": "text",
      "id": "read_more_label",
      "label": "Expandable row — label",
      "default": "Yes, this actually works."
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count (display)",
      "default": "312"
    }
  ],
  "presets": [
    {
      "name": "Product Highlight"
    }
  ]
}
{% endschema %}
