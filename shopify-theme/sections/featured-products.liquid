{% assign product = section.settings.product %}

<section class="product-highlight">
  <div class="product-highlight__inner">
    <div class="product-highlight__gallery">
      <div class="product-highlight__main-image">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            loading="lazy"
            width="900"
            height="900"
          >
        {% elsif section.settings.image %}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ product.title | escape }}"
            loading="lazy"
            width="900"
            height="900"
          >
        {% else %}
          <div class="product-highlight__placeholder"></div>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="product-highlight__thumbnails">
          {% for img in product.images limit: 5 %}
            <div class="product-highlight__thumb{% if forloop.first %} product-highlight__thumb--active{% endif %}">
              <img
                src="{{ img | image_url: width: 120 }}"
                alt="{{ img.alt | default: product.title | escape }}"
                loading="lazy"
                width="120"
                height="120"
              >
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product-highlight__details">
      {% if section.settings.show_rating %}
        <div class="product-highlight__rating">
          <span class="product-highlight__stars">★★★★★</span>
          <span class="product-highlight__reviews">({{ section.settings.review_count }})</span>
        </div>
      {% endif %}

      <h2 class="product-highlight__title">{{ product.title | default: section.settings.fallback_title }}</h2>

      <div class="product-highlight__pricing">
        {% if product %}
          <span class="product-highlight__price">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="product-highlight__compare-price">{{ product.compare_at_price | money }}</span>
          {% endif %}
        {% else %}
          <span class="product-highlight__price">$59.99</span>
        {% endif %}
      </div>

      {% if product.description != blank %}
        <p class="product-highlight__description">{{ product.description | strip_html | truncate: 250 }}</p>
      {% elsif section.settings.custom_description != blank %}
        <p class="product-highlight__description">{{ section.settings.custom_description }}</p>
      {% endif %}

      {% if product %}
        <form method="post" action="/cart/add">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" class="product-highlight__button"{% unless product.available %} disabled{% endunless %}>
            {% if product.available %}
              {{ section.settings.button_text }}
            {% else %}
              Sold Out
            {% endif %}
          </button>
        </form>
      {% else %}
        <a href="#" class="product-highlight__button">
          {{ section.settings.button_text }}
        </a>
      {% endif %}

      {% if section.settings.subtext != blank %}
        <p class="product-highlight__subtext">{{ section.settings.subtext }}</p>
      {% endif %}

      {% if product %}
        <a href="{{ product.url }}" class="product-highlight__view-link">View Full Details →</a>
      {% endif %}

      {% assign bundle_1 = section.settings.bundle_product_1 %}
      {% assign bundle_2 = section.settings.bundle_product_2 %}
      {% assign bundle_3 = section.settings.bundle_product_3 %}

      {% if bundle_1 != blank or bundle_2 != blank or bundle_3 != blank %}
        <div class="bundle">
          <h3 class="bundle__heading">Buy More and Save</h3>

          {% for i in (1..3) %}
            {% case i %}
              {% when 1 %}
                {% assign bp = bundle_1 %}
                {% assign savings = section.settings.bundle_savings_1 %}
              {% when 2 %}
                {% assign bp = bundle_2 %}
                {% assign savings = section.settings.bundle_savings_2 %}
              {% when 3 %}
                {% assign bp = bundle_3 %}
                {% assign savings = section.settings.bundle_savings_3 %}
            {% endcase %}

            {% if bp != blank %}
              <div class="bundle__card">
                <div class="bundle__card-left">
                  <div class="bundle__card-image">
                    {% if bp.featured_image %}
                      <img
                        src="{{ bp.featured_image | image_url: width: 140 }}"
                        alt="{{ bp.title | escape }}"
                        width="140"
                        height="140"
                        loading="lazy"
                      >
                    {% endif %}
                  </div>
                  <div class="bundle__card-info">
                    <p class="bundle__card-name">{{ bp.title }}</p>
                    {% if bp.variants.size > 1 %}
                      <div class="bundle__card-variant">
                        <select class="bundle__card-select" data-bundle-index="{{ i }}">
                          {% for variant in bp.variants %}
                            <option value="{{ variant.id }}">{{ variant.title }}</option>
                          {% endfor %}
                        </select>
                      </div>
                    {% endif %}
                  </div>
                </div>
                <div class="bundle__card-right">
                  <div class="bundle__card-price-wrap">
                    <span class="bundle__card-price">{{ bp.price | money }}</span>
                    {% if savings != blank %}
                      <span class="bundle__card-savings">{{ savings }}</span>
                    {% elsif bp.compare_at_price > bp.price %}
                      <span class="bundle__card-savings">SAVE {{ bp.compare_at_price | minus: bp.price | money }}</span>
                    {% endif %}
                  </div>
                  <form method="post" action="/cart/add" class="bundle__card-form">
                    <input type="hidden" name="id" value="{{ bp.selected_or_first_available_variant.id }}" class="bundle-variant-id-{{ i }}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="bundle__card-btn"{% unless bp.available %} disabled{% endunless %}>
                      {% if bp.available %}Add to Cart{% else %}Sold Out{% endif %}
                    </button>
                  </form>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.bundle__card-select').forEach(function(select) {
    select.addEventListener('change', function() {
      var index = this.dataset.bundleIndex;
      var input = document.querySelector('.bundle-variant-id-' + index);
      if (input) input.value = this.value;
    });
  });
</script>

{% stylesheet %}
  .product-highlight {
    padding: 60px 24px 16px;
  }

  .product-highlight__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1100px;
    margin: 0 auto;
    align-items: start;
  }

  @media (max-width: 900px) {
    .product-highlight__inner {
      grid-template-columns: 1fr;
      gap: 32px;
      max-width: 550px;
    }
  }

  .product-highlight__main-image {
    border-radius: 12px;
    overflow: hidden;
    background: #f5f5f5;
    aspect-ratio: 1 / 1;
  }

  .product-highlight__main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-highlight__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8e8e8 0%, #d0d0d0 100%);
  }

  .product-highlight__thumbnails {
    display: flex;
    gap: 10px;
    margin-top: 12px;
  }

  .product-highlight__thumb {
    width: 72px;
    height: 72px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid #e0e0e0;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .product-highlight__thumb--active,
  .product-highlight__thumb:hover {
    border-color: #1a1a1a;
  }

  .product-highlight__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-highlight__details {
    padding-top: 8px;
  }

  .product-highlight__rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
  }

  .product-highlight__stars {
    color: #f5c518;
    font-size: 18px;
    letter-spacing: 2px;
  }

  .product-highlight__reviews {
    font-size: 14px;
    color: #666;
  }

  .product-highlight__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 16px;
    color: #1a1a1a;
  }

  .product-highlight__pricing {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .product-highlight__price {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .product-highlight__compare-price {
    font-size: 1.1rem;
    color: #999;
    text-decoration: line-through;
  }

  .product-highlight__description {
    font-size: 1rem;
    line-height: 1.7;
    color: #444;
    margin-bottom: 28px;
  }

  .product-highlight__button {
    display: block;
    width: 100%;
    text-align: center;
    background-color: #1a1a1a;
    color: #fff;
    padding: 16px 32px;
    font-size: 15px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.2s;
    font-family: inherit;
  }

  .product-highlight__button:hover {
    background-color: #333;
    transform: translateY(-2px);
  }

  .product-highlight__button[disabled] {
    background-color: #ccc;
    cursor: not-allowed;
    transform: none;
  }

  .product-highlight__subtext {
    text-align: center;
    font-size: 13px;
    color: #888;
    margin-top: 12px;
  }

  .product-highlight__view-link {
    display: block;
    text-align: center;
    margin-top: 16px;
    font-size: 14px;
    color: #1a1a1a;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .product-highlight__view-link:hover {
    opacity: 0.6;
  }

  /* Bundle styles */
  .bundle {
    margin-top: 32px;
  }

  .bundle__heading {
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 12px;
  }

  .bundle__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px;
    border: 2px solid #d4e8d0;
    border-radius: 14px;
    margin-bottom: 10px;
    background: #fafffe;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .bundle__card:hover {
    border-color: #a8d5a0;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .bundle__card-left {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 0;
  }

  .bundle__card-image {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: #f0f0f0;
  }

  .bundle__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bundle__card-info {
    min-width: 0;
  }

  .bundle__card-name {
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bundle__card-variant {
    margin-top: 2px;
  }

  .bundle__card-select {
    font-size: 13px;
    color: #555;
    padding: 4px 8px;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
  }

  .bundle__card-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
    margin-left: 12px;
  }

  .bundle__card-price-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bundle__card-price {
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
  }

  .bundle__card-savings {
    font-size: 11px;
    font-weight: 700;
    color: #16a34a;
    background: #dcfce7;
    padding: 3px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  .bundle__card-btn {
    background: #d4edda;
    color: #1a1a1a;
    border: 1px solid #b8d9be;
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
    font-family: inherit;
    white-space: nowrap;
  }

  .bundle__card-btn:hover {
    background: #c1e6c9;
  }

  .bundle__card-btn[disabled] {
    background: #eee;
    color: #999;
    border-color: #ddd;
    cursor: not-allowed;
  }

  @media (max-width: 500px) {
    .bundle__card {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }

    .bundle__card-right {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      margin-left: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Highlight",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Override Image",
      "info": "Optional. Overrides the product's featured image."
    },
    {
      "type": "header",
      "content": "Custom Text (used if no product selected)"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback Title",
      "default": "Silent Alarm Wristband"
    },
    {
      "type": "textarea",
      "id": "custom_description",
      "label": "Custom Description",
      "info": "Used if the product has no description.",
      "default": "Wake up gently with a silent vibrating alarm that won't disturb your partner."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Add To Cart"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext below button",
      "default": "Free shipping across USA & Canada"
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating",
      "default": true
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count",
      "default": "312"
    },
    {
      "type": "header",
      "content": "Bundle 1"
    },
    {
      "type": "product",
      "id": "bundle_product_1",
      "label": "Bundle Product 1"
    },
    {
      "type": "text",
      "id": "bundle_savings_1",
      "label": "Savings Text",
      "info": "e.g. 'SAVE $10'. Auto-calculated if left blank."
    },
    {
      "type": "header",
      "content": "Bundle 2"
    },
    {
      "type": "product",
      "id": "bundle_product_2",
      "label": "Bundle Product 2"
    },
    {
      "type": "text",
      "id": "bundle_savings_2",
      "label": "Savings Text",
      "info": "e.g. 'SAVE $15'. Auto-calculated if left blank."
    },
    {
      "type": "header",
      "content": "Bundle 3"
    },
    {
      "type": "product",
      "id": "bundle_product_3",
      "label": "Bundle Product 3"
    },
    {
      "type": "text",
      "id": "bundle_savings_3",
      "label": "Savings Text",
      "info": "e.g. 'SAVE $20'. Auto-calculated if left blank."
    }
  ],
  "presets": [
    {
      "name": "Product Highlight"
    }
  ]
}
{% endschema %}
