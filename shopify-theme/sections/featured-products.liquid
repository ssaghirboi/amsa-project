{% assign product = section.settings.product %}

{{ 'product-highlight.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-variant-picker.js' | asset_url }}" defer></script>

<section
  class="product-highlight"
  id="ProductHighlight-{{ section.id }}"
>
  <div class="product-highlight__panel">
    <div class="product-highlight__inner">
      <div class="product-highlight__gallery">
        <div class="product-highlight__main-image">
          {% if product and product.images.size > 0 %}
            {% assign main_img = product.images.first %}
            <img
              data-ph-main
              src="{{ main_img | image_url: width: 1200 }}"
              alt="{{ main_img.alt | default: product.title | escape }}"
              loading="lazy"
              width="1200"
              height="1200"
            >
          {% elsif product and product.featured_image %}
            <img
              data-ph-main
              src="{{ product.featured_image | image_url: width: 1200 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              loading="lazy"
              width="1200"
              height="1200"
            >
          {% elsif section.settings.image %}
            <img
              data-ph-main
              src="{{ section.settings.image | image_url: width: 1200 }}"
              alt="{{ section.settings.image.alt | default: product.title | escape }}"
              loading="lazy"
              width="1200"
              height="1200"
            >
          {% else %}
            <div class="product-highlight__placeholder" role="img" aria-label="{{ product.title | default: 'Product' }}"></div>
          {% endif %}
        </div>

        {% if product and product.images.size > 1 %}
          <div class="product-highlight__thumbnails">
            {% for img in product.images limit: 8 %}
              <button
                type="button"
                class="product-highlight__thumb{% if forloop.first %} is-active{% endif %}"
                data-ph-thumb
                data-full="{{ img | image_url: width: 1200 }}"
                aria-label="Show image {{ forloop.index }}"
              >
                <img
                  src="{{ img | image_url: width: 120 }}"
                  alt="{{ img.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="120"
                  height="120"
                >
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="product-highlight__details">
        {% if product %}
          {% assign fh_variant = product.selected_or_first_available_variant %}
        {% else %}
          {% assign fh_variant = nil %}
        {% endif %}

        <div class="product-highlight__title-row">
          <h2 class="product-highlight__title">
            {{ product.title | default: section.settings.fallback_title }}
          </h2>
          <div class="product-highlight__price-wrap">
            {% if product %}
              <span class="product-highlight__price" data-ph-price>{{ fh_variant.price | money }}</span>
              {% if fh_variant.compare_at_price > fh_variant.price %}
                <span class="product-highlight__compare-price" data-ph-compare-price>{{ fh_variant.compare_at_price | money }}</span>
              {% else %}
                <span class="product-highlight__compare-price" data-ph-compare-price hidden></span>
              {% endif %}
            {% else %}
              <span class="product-highlight__price">—</span>
            {% endif %}
          </div>
        </div>

        {% if section.settings.show_rating %}
          <div class="product-highlight__rating">
            <span class="product-highlight__stars" aria-hidden="true">★★★★★</span>
            <span class="product-highlight__reviews">({{ section.settings.review_count }})</span>
          </div>
        {% endif %}

        {% if product and product.description != blank %}
          <div class="product-highlight__description rte">{{ product.description | strip_html | truncate: 320 }}</div>
        {% elsif section.settings.custom_description != blank %}
          <p class="product-highlight__description">{{ section.settings.custom_description }}</p>
        {% endif %}

        {% if product %}
          <form method="post" action="{{ routes.cart_add_url }}">
            {% if product.variants.size > 1 %}
              {% render 'product-variant-picker',
                product: product,
                section_id: section.id,
                current_variant: fh_variant
              %}
            {% else %}
              <input type="hidden" name="id" value="{{ fh_variant.id }}">
            {% endif %}
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              class="product-highlight__button product-highlight__button--primary"
              data-add-label="{{ section.settings.button_text | escape }}"
              data-sold-label="Sold out"
              {% unless fh_variant.available %}
                disabled
              {% endunless %}
            >
              {% if fh_variant.available %}
                {{ section.settings.button_text }}
              {% else %}
                Sold out
              {% endif %}
            </button>
          </form>
        {% else %}
          <span class="product-highlight__button" style="display: inline-block; opacity: 0.5; pointer-events: none;">
            {{ section.settings.button_text }}
          </span>
        {% endif %}

        {% if section.settings.subtext != blank %}
          <p class="product-highlight__subtext">{{ section.settings.subtext }}</p>
        {% endif %}

        {% if product %}
          <a href="{{ product.url }}" class="product-highlight__view-link">
            {{ section.settings.view_full_label }}
          </a>
        {% endif %}

        {% assign bundle_1 = section.settings.bundle_product_1 %}
        {% assign bundle_2 = section.settings.bundle_product_2 %}
        {% assign bundle_3 = section.settings.bundle_product_3 %}

        {% if bundle_1 != blank or bundle_2 != blank or bundle_3 != blank %}
          <div class="bundle-pills">
            <h3 class="bundle-pills__heading">{{ section.settings.bundle_heading }}</h3>

            {% for i in (1..3) %}
              {% case i %}
                {% when 1 %}
                  {% assign bp = bundle_1 %}
                {% when 2 %}
                  {% assign bp = bundle_2 %}
                {% when 3 %}
                  {% assign bp = bundle_3 %}
              {% endcase %}

              {% if bp != blank %}
                <form method="post" action="{{ routes.cart_add_url }}" class="bundle-pill-form" data-bundle-form data-bundle-section="{{ section.id }}-{{ i }}">
                  <input type="hidden" name="quantity" value="1">
                  <input type="hidden" name="id" value="{{ bp.selected_or_first_available_variant.id }}" data-bundle-variant-id>
                  {% if bp.variants.size > 1 %}
                    <div class="bundle-pill__chooser" role="group" aria-label="{{ bp.title }} — options">
                      {% for variant in bp.variants %}
                        <button
                          type="button"
                          class="bundle-pill__opt{% if variant == bp.selected_or_first_available_variant %} is-active{% endif %}"
                          data-variant-id="{{ variant.id }}"
                          {% unless variant.available %}
                            disabled
                          {% endunless %}
                        >
                          {{ variant.title }}
                        </button>
                      {% endfor %}
                    </div>
                  {% endif %}
                  <div class="bundle-pill">
                    <span class="bundle-pill__name">{{ bp.title }}</span>
                    <button type="submit" class="bundle-pill__action"{% unless bp.available %} disabled{% endunless %}>
                      {% if bp.available %}
                        {{ section.settings.bundle_button_label }}
                      {% else %}
                        Sold out
                      {% endif %}
                    </button>
                  </div>
                </form>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('ProductHighlight-{{ section.id }}');
    if (!root) return;
    var main = root.querySelector('[data-ph-main]');
    if (main) {
      root.querySelectorAll('[data-ph-thumb]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var url = btn.getAttribute('data-full');
          if (url) {
            main.src = url;
            main.removeAttribute('srcset');
          }
          root.querySelectorAll('[data-ph-thumb]').forEach(function (b) {
            b.classList.remove('is-active');
          });
          btn.classList.add('is-active');
        });
      });
    }

    root.querySelectorAll('[data-bundle-form]').forEach(function (form) {
      form.querySelectorAll('.bundle-pill__opt').forEach(function (opt) {
        opt.addEventListener('click', function () {
          var id = opt.getAttribute('data-variant-id');
          var hidden = form.querySelector('[data-bundle-variant-id]');
          if (hidden && id) hidden.value = id;
          form.querySelectorAll('.bundle-pill__opt').forEach(function (o) {
            o.classList.toggle('is-active', o === opt);
          });
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product Highlight",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Override image",
      "info": "Optional. Used when no product is selected, or as fallback."
    },
    {
      "type": "header",
      "content": "Custom text (if no product)"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback title",
      "default": "Silent Alarm Wristband"
    },
    {
      "type": "textarea",
      "id": "custom_description",
      "label": "Custom description",
      "info": "Shown when the product has no description.",
      "default": "Wake up gently with a silent vibrating alarm that won't disturb your partner. Lightweight, comfortable, and designed for the deepest sleepers."
    },
    {
      "type": "header",
      "content": "Primary action"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Add to cart label",
      "default": "Add to cart"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Line under button",
      "default": "Free shipping"
    },
    {
      "type": "text",
      "id": "view_full_label",
      "label": "Link to product page",
      "default": "View full details"
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count (display)",
      "default": "312"
    },
    {
      "type": "header",
      "content": "Bundles"
    },
    {
      "type": "text",
      "id": "bundle_heading",
      "label": "Bundle section heading",
      "default": "Bundle and save"
    },
    {
      "type": "text",
      "id": "bundle_button_label",
      "label": "Bundle row button",
      "default": "Add"
    },
    {
      "type": "header",
      "content": "Bundle product 1"
    },
    {
      "type": "product",
      "id": "bundle_product_1",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Bundle product 2"
    },
    {
      "type": "product",
      "id": "bundle_product_2",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Bundle product 3"
    },
    {
      "type": "product",
      "id": "bundle_product_3",
      "label": "Product"
    }
  ],
  "presets": [
    {
      "name": "Product Highlight"
    }
  ]
}
{% endschema %}
