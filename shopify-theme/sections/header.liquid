<header class="site-header">
  <div class="site-header__start">
    <nav class="header__menu" aria-label="Primary">
      {% for link in section.settings.menu.links %}
        {{ link.title | link_to: link.url }}
      {% endfor %}
    </nav>
  </div>

  <div class="site-header__logo">
    <h2 class="header__title">
      {{ shop.name | link_to: routes.root_url }}
    </h2>
  </div>

  <div class="site-header__end">
    <div class="header__icons">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a href="{{ routes.cart_url }}" class="header__cart-link" data-cart-drawer-open aria-label="{{ 'cart.title' | t }}">
        <span class="header__cart-badge" data-header-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header {
    min-height: 5.5rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding-inline: var(--page-margin, 1rem);
    padding-top: max(0.5rem, env(safe-area-inset-top, 0px));
    padding-bottom: 0.35rem;
    max-width: var(--page-width, 100%);
    margin-inline: auto;
  }

  .site-header__start {
    justify-self: start;
    min-width: 0;
  }

  .site-header__logo {
    justify-self: center;
    text-align: center;
  }

  .site-header__end {
    justify-self: end;
  }

  .header__title {
    margin: 0;
    font-size: clamp(1.35rem, 2.8vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .header__title a {
    text-decoration: none;
    color: var(--color-foreground);
  }

  .site-header a {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header__cart-link {
    position: relative;
  }

  .header__cart-badge {
    position: absolute;
    top: -0.2rem;
    right: -0.35rem;
    min-width: 1.15rem;
    height: 1.15rem;
    padding: 0 0.3rem;
    border-radius: 999px;
    background: var(--color-foreground);
    color: var(--color-background);
    font-size: 0.65rem;
    font-weight: 700;
    line-height: 1.15rem;
    text-align: center;
  }

  .header__cart-badge[hidden] {
    display: none;
  }

  .site-header svg {
    width: 2rem;
  }

  .header__menu,
  .header__icons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .header__menu {
    font-size: 0.95rem;
    font-weight: 500;
  }

  @media (max-width: 700px) {
    .site-header {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      text-align: center;
      padding-block: 0.75rem;
    }

    .site-header__start,
    .site-header__logo,
    .site-header__end {
      justify-self: center;
    }

    .header__menu {
      justify-content: center;
    }

    .header__icons {
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
