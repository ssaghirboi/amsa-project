<section
  class="reviews-showcase"
  id="reviews-carousel-{{ section.id }}"
  data-reviews-root
>
  <div class="reviews-showcase__inner">
    {% if section.settings.heading != blank %}
      <h2 class="reviews-showcase__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="reviews-showcase__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="reviews-showcase__shell">
        <button
          type="button"
          class="reviews-showcase__nav reviews-showcase__nav--prev"
          aria-label="Previous review"
          data-carousel-prev
        >
          <span aria-hidden="true">‹</span>
        </button>

        <div
          class="reviews-showcase__window"
          data-carousel-window
          tabindex="0"
          role="region"
          aria-roledescription="carousel"
          aria-label="{{ section.settings.heading | default: 'Customer reviews' | escape }}"
        >
          {% for block in section.blocks %}
            <article
              class="reviews-showcase__slide"
              data-carousel-slide
              role="group"
              aria-roledescription="slide"
              aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}"
              {{ block.shopify_attributes }}
            >
              <div class="reviews-showcase__card">
                <header class="reviews-showcase__card-head">
                  <span class="reviews-showcase__author">{{ block.settings.author }}</span>
                </header>
                <div class="reviews-showcase__stars" aria-hidden="true">
                  {% assign r = block.settings.rating | default: 5 | plus: 0 %}
                  {% for i in (1..5) %}
                    <span class="reviews-showcase__star-wrap{% if i > r %} reviews-showcase__star-wrap--dim{% endif %}">
                      <svg class="reviews-showcase__star-svg" viewBox="0 0 24 24" width="32" height="32" focusable="false">
                        <path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    </span>
                  {% endfor %}
                </div>
                <blockquote class="reviews-showcase__quote">
                  <p>{{ block.settings.quote }}</p>
                </blockquote>
                {% if block.settings.subtitle != blank %}
                  <p class="reviews-showcase__subtitle">{{ block.settings.subtitle }}</p>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>

        <button
          type="button"
          class="reviews-showcase__nav reviews-showcase__nav--next"
          aria-label="Next review"
          data-carousel-next
        >
          <span aria-hidden="true">›</span>
        </button>
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('reviews-carousel-{{ section.id }}');
    if (!root) return;

    var windowEl = root.querySelector('[data-carousel-window]');
    var slides = Array.prototype.slice.call(root.querySelectorAll('[data-carousel-slide]'));
    var prevBtn = root.querySelector('[data-carousel-prev]');
    var nextBtn = root.querySelector('[data-carousel-next]');
    if (!windowEl || slides.length === 0) return;

    var index = 0;
    var autoplayMs = {{ section.settings.autoplay_seconds | default: 8 | times: 1000 }};
    var timer = null;
    var prefersReduced =
      typeof window.matchMedia === 'function' &&
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function centerSlide(i) {
      if (i < 0 || i >= slides.length) return;
      var slide = slides[i];
      var target =
        slide.offsetLeft - (windowEl.clientWidth - slide.offsetWidth) / 2;
      windowEl.scrollTo({
        left: Math.max(0, target),
        behavior: prefersReduced ? 'auto' : 'smooth',
      });
    }

    function go(delta) {
      index = (index + delta + slides.length) % slides.length;
      centerSlide(index);
    }

    function startAutoplay() {
      stopAutoplay();
      if (prefersReduced || slides.length < 2) return;
      timer = window.setInterval(function () {
        go(1);
      }, autoplayMs);
    }

    function stopAutoplay() {
      if (timer) {
        window.clearInterval(timer);
        timer = null;
      }
    }

    if (prevBtn) prevBtn.addEventListener('click', function () {
      go(-1);
      startAutoplay();
    });
    if (nextBtn) nextBtn.addEventListener('click', function () {
      go(1);
      startAutoplay();
    });

    windowEl.addEventListener('scroll', function () {
      if (!windowEl.scrollWidth) return;
      var mid = windowEl.scrollLeft + windowEl.clientWidth / 2;
      var best = 0;
      var bestDist = Infinity;
      for (var s = 0; s < slides.length; s++) {
        var el = slides[s];
        var c = el.offsetLeft + el.offsetWidth / 2;
        var d = Math.abs(c - mid);
        if (d < bestDist) {
          bestDist = d;
          best = s;
        }
      }
      index = best;
    }, { passive: true });

    windowEl.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        go(-1);
        startAutoplay();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        go(1);
        startAutoplay();
      }
    });

    root.addEventListener('mouseenter', stopAutoplay);
    root.addEventListener('mouseleave', startAutoplay);
    root.addEventListener('focusin', stopAutoplay);
    root.addEventListener('focusout', function (e) {
      if (!root.contains(e.relatedTarget)) startAutoplay();
    });

    document.addEventListener('visibilitychange', function () {
      if (document.hidden) stopAutoplay();
      else startAutoplay();
    });

    window.addEventListener(
      'resize',
      function () {
        centerSlide(index);
      },
      { passive: true }
    );

    requestAnimationFrame(function () {
      centerSlide(0);
      startAutoplay();
    });
  })();
</script>

{% stylesheet %}
  .reviews-showcase {
    padding: clamp(2.5rem, 6vw, 4rem) var(--page-margin, 1rem);
    background: var(--color-background);
  }

  .reviews-showcase__inner {
    max-width: min(var(--page-width, 1100px), 100%);
    margin: 0 auto;
  }

  .reviews-showcase__heading {
    font-size: clamp(1.65rem, 3.8vw, 2.25rem);
    font-weight: 800;
    text-align: center;
    margin: 0 0 0.5rem;
    color: var(--color-foreground);
    letter-spacing: -0.03em;
  }

  .reviews-showcase__subheading {
    text-align: center;
    color: color-mix(in srgb, var(--color-foreground) 52%, var(--color-background));
    font-size: clamp(1.08rem, 2vw, 1.2rem);
    margin: 0 0 2rem;
    max-width: 38rem;
    margin-inline: auto;
    line-height: 1.55;
    letter-spacing: -0.01em;
  }

  .reviews-showcase__shell {
    display: flex;
    align-items: stretch;
    gap: 0.35rem;
    background: transparent;
    border-radius: 1.25rem;
    padding: clamp(0.75rem, 2vw, 1rem) clamp(0.25rem, 1.5vw, 0.5rem);
    border: 1px solid color-mix(in srgb, var(--color-foreground) 10%, var(--color-background));
  }

  @media (min-width: 640px) {
    .reviews-showcase__shell {
      gap: 0.65rem;
      padding: clamp(1rem, 2.5vw, 1.35rem) clamp(0.5rem, 1.5vw, 0.85rem);
    }
  }

  .reviews-showcase__nav {
    flex: 0 0 auto;
    align-self: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 14%, var(--color-background));
    border-radius: 0.75rem;
    background: var(--color-background);
    color: var(--color-foreground);
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, transform 0.1s ease;
  }

  .reviews-showcase__nav:hover {
    background: color-mix(in srgb, var(--color-foreground) 5%, var(--color-background));
  }

  .reviews-showcase__nav:active {
    transform: scale(0.96);
  }

  .reviews-showcase__nav span {
    display: block;
    margin-top: -0.1em;
  }

  .reviews-showcase__window {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scroll-padding-inline: 8%;
    padding-inline: 8%;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    outline: none;
  }

  .reviews-showcase__window::-webkit-scrollbar {
    display: none;
  }

  .reviews-showcase__slide {
    flex: 0 0 min(86%, 460px);
    scroll-snap-align: center;
    scroll-snap-stop: always;
    display: flex;
    align-items: stretch;
  }

  .reviews-showcase__card {
    width: 100%;
    min-height: clamp(22rem, 52vh, 32rem);
    background: color-mix(in srgb, var(--color-foreground) 4%, var(--color-background));
    border-radius: 1.125rem;
    padding: clamp(1.85rem, 4vw, 2.5rem) clamp(1.55rem, 3.5vw, 2.1rem);
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 9%, var(--color-background));
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(0);
    transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
  }

  .reviews-showcase__slide:hover .reviews-showcase__card {
    border-color: color-mix(in srgb, var(--color-foreground) 14%, var(--color-background));
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .reviews-showcase__slide:hover .reviews-showcase__card {
      transform: none;
    }
  }

  .reviews-showcase__card-head {
    margin: 0;
  }

  .reviews-showcase__author {
    display: block;
    font-weight: 800;
    font-size: clamp(1.2rem, 2.4vw, 1.4rem);
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    line-height: 1.25;
  }

  .reviews-showcase__stars {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .reviews-showcase__star-wrap {
    display: flex;
    line-height: 0;
    color: #ca8a04;
  }

  .reviews-showcase__star-wrap--dim {
    color: color-mix(in srgb, var(--color-foreground) 18%, var(--color-background));
  }

  .reviews-showcase__star-svg {
    width: clamp(2.1rem, 4.8vw, 2.65rem);
    height: clamp(2.1rem, 4.8vw, 2.65rem);
    display: block;
  }

  .reviews-showcase__quote {
    margin: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .reviews-showcase__quote p {
    margin: 0;
    font-size: clamp(1.12rem, 2.25vw, 1.32rem);
    line-height: 1.65;
    letter-spacing: -0.015em;
    color: color-mix(in srgb, var(--color-foreground) 90%, var(--color-background));
    font-weight: 400;
  }

  .reviews-showcase__subtitle {
    margin: 0;
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: clamp(0.95rem, 1.65vw, 1.05rem);
    color: color-mix(in srgb, var(--color-foreground) 48%, var(--color-background));
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  @media (max-width: 639px) {
    .reviews-showcase__shell {
      flex-wrap: nowrap;
    }

    .reviews-showcase__nav {
      width: 2.15rem;
      height: 2.15rem;
      font-size: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer reviews",
  "tag": "section",
  "class": "section-reviews-showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What customers say"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Thousands of happy sleepers trust SleepRizer for quieter mornings and deeper rest."
    },
    {
      "type": "range",
      "id": "autoplay_seconds",
      "min": 4,
      "max": 20,
      "step": 1,
      "unit": "s",
      "label": "Auto-advance interval",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Stars",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review text",
          "default": "Game changer for my sleep. Wish I found this sooner."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Name",
          "default": "Alex M."
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "info": "e.g. city or “Verified buyer”",
          "default": "Verified buyer"
        }
      ]
    }
  ],
